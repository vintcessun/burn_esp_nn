{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "toolchain": {
      "type": "object",
      "properties": {
        "channel": {
          "type": "string",
          "enum": [
            "stable",
            "beta",
            "nightly",
            "esp"
          ]
        },
        "components": {
          "type": "array",
          "items": { "type": "string" }
        },
        "targets": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["channel"]
    }
  }
}